<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<title>Boca Juegos</title>

<style>

body{
margin:0;
font-family:Arial;
background:linear-gradient(#001a5c,#000428);
color:white;
text-align:center;
}

header{
background:#002b9f;
padding:25px;
font-size:40px;
font-weight:bold;
box-shadow:0 0 20px black;
}

section{
background:#002b7f;
margin:20px;
padding:20px;
border-radius:20px;
box-shadow:0 0 20px black;
}

button{
background:gold;
border:none;
padding:12px 20px;
border-radius:10px;
font-weight:bold;
cursor:pointer;
transition:0.3s;
}

button:hover{
transform:scale(1.1);
}

.card{
width:120px;
height:160px;
background:linear-gradient(gold,#ffcc00);
color:black;
border-radius:15px;
display:inline-block;
margin:10px;
padding:10px;
font-weight:bold;
}

.sobre{
width:150px;
height:200px;
background:linear-gradient(#003cff,#001f6b);
margin:auto;
border-radius:15px;
display:flex;
align-items:center;
justify-content:center;
font-weight:bold;
animation:brillo 1s infinite alternate;
}

@keyframes brillo{
from{box-shadow:0 0 10px gold}
to{box-shadow:0 0 40px gold}
}

table{
margin:auto;
border-collapse:collapse;
}

td,th{
border:1px solid gold;
padding:10px;
}

</style>
</head>

<body>

<div id="inicio" style="position:fixed;top:0;left:0;width:100%;height:100%;background:#001f6b;display:flex;flex-direction:column;align-items:center;justify-content:center;z-index:9999;">
<h1 style="font-size:60px;">💙 BOCA JUEGOS 💛</h1>
<button style="font-size:25px;" onclick="empezar()">JUGAR</button>
</div>

<header>💙 BOCA JUEGOS 💛</header>

<!-- SOBRE -->
<section>

<h2>🃏 Abrir sobre</h2>

<div class="sobre">SOBRE</div>

<br>

<button onclick="abrirSobre()">Abrir</button>

<div id="carta"></div>

</section>

<!-- DRAFT -->

<section>

<h2>⚽ Draft</h2>

<button onclick="draft()">Elegir jugador</button>

<div id="equipo"></div>

<p id="media"></p>

</section>

<!-- COPA -->

<section>

<h2>🏆 Copa Xeneize</h2>

<p id="ronda">Octavos</p>

<button onclick="jugar()">Jugar</button>

<p id="resultado"></p>

</section>

<!-- QUIZ -->

<section>

<h2>🧠 Quiz Boca</h2>

<p id="pregunta"></p>

<input id="respuesta">

<button onclick="quiz()">Responder</button>

<p id="quizr"></p>

</section>

<!-- PREDICCION -->

<section>

<h2>🔮 Predicción Boca vs River</h2>

<input id="pred">

<button onclick="pred()">Enviar</button>

<p id="predr"></p>

</section>

<!-- MODO DT -->

<section>

<h2>🧑‍💼 Carrera DT</h2>

<select id="dt">

<option>Carlos Bianchi</option>
<option>Miguel Russo</option>
<option>Guillermo Barros Schelotto</option>
<option>Sebastián Battaglia</option>

</select>

<br><br>

<button onclick="carrera()">Comenzar</button>

<p id="carreratexto"></p>

</section>

<!-- MERCADO -->

<section>

<h2>💰 Mercado</h2>

<button onclick="mercado()">Mostrar</button>

<div id="mercado"></div>

</section>

<!-- RANKING -->

<section>

<h2>🌎 Ranking</h2>

<input id="nombre" placeholder="Tu nombre">

<button onclick="guardar()">Guardar puntos</button>

<table id="tabla">

<tr>

<th>Jugador</th>

<th>Puntos</th>

</tr>

</table>

</section>

<!-- CANALES -->

<section>

<h2>📺 Canal 1</h2>

<a href="https://youtube.com/@bolavip.xeneize.oficial?si=qAIthfiDSKXJWuT-" target="_blank">

<button>Ver canal</button>

</a>

</section>

<section>

<h2>📺 Canal 2</h2>

<a href="https://youtube.com/@bolavipxeneizesgamer?si=r4uZwARqZXplSIC0" target="_blank">

<button>Ver canal</button>

</a>

</section>

<script>

function empezar(){

document.getElementById("inicio").style.display="none"

}

let puntos=0

let jugadores=[

["Riquelme",99],
["Maradona",99],
["Palermo",97],
["Tevez",98],
["Cavani",93],
["Merentiel",96],
["Zenon",92],
["Paredes",95],
["Barrios",90],
["Battaglia",89],
["Samuel",92],
["Cordoba",94]

]

function abrirSobre(){

let j=jugadores[Math.floor(Math.random()*jugadores.length)]

document.getElementById("carta").innerHTML=

"<div class='card'>"+j[0]+"<br>"+j[1]+"</div>"

puntos+=10

}

let equipo=[]

function draft(){

if(equipo.length>=11)return

let j=jugadores[Math.floor(Math.random()*jugadores.length)]

equipo.push(j)

document.getElementById("equipo").innerHTML+=

"<div class='card'>"+j[0]+"<br>"+j[1]+"</div>"

let total=0

for(let i of equipo)total+=i[1]

document.getElementById("media").innerText="Media "+Math.floor(total/equipo.length)

}

let ronda=0

let rondas=["Octavos","Cuartos","Semi","Final","Campeón"]

function jugar(){

let g=Math.random()>0.4

if(g){

ronda++

puntos+=20

document.getElementById("resultado").innerText="Ganaste"

document.getElementById("ronda").innerText=rondas[ronda]

}else{

document.getElementById("resultado").innerText="Perdiste"

}

}

let pregunta="¿Quién hizo el gol a Real Madrid en 2000?"

document.getElementById("pregunta").innerText=pregunta

function quiz(){

let r=document.getElementById("respuesta").value.toLowerCase()

if(r.includes("palermo")){

document.getElementById("quizr").innerText="Correcto"

puntos+=30

}else{

document.getElementById("quizr").innerText="Incorrecto"

}

}

function pred(){

let r=Math.floor(Math.random()*5)

document.getElementById("predr").innerText="Resultado posible Boca "+r+" - "+Math.floor(Math.random()*4)

}

function carrera(){

let dt=document.getElementById("dt").value

document.getElementById("carreratexto").innerText="Elegiste a "+dt+" como DT"

puntos+=10

}

function mercado(){

let lista=["Messi","Di Maria","Alvarez","Mac Allister"]

for(let j of lista){

document.getElementById("mercado").innerHTML+=

"<div class='card'>"+j+"</div>"

}

}

function guardar(){

let n=document.getElementById("nombre").value

let fila="<tr><td>"+n+"</td><td>"+puntos+"</td></tr>"

document.getElementById("tabla").innerHTML+=fila

}

</script>

</body>
</html>